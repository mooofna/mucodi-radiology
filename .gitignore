/data/*
!/data/reproducibility/
/data/reproducibility/.scratch/
/runs
/logs
/checkpoints
/wandb
/.cache
experiments/runs
experiments/studies/*/results/
*.pt
*.pth
*.pth.tar
*.log
*.err
*.out

# Cluster secrets (HF_TOKEN / ZENODO / KAGGLE / REDIVIS). Template: jobs/secrets.env.example
/jobs/secrets.env
/jobs/logs/

# Default storage roots when jobs/env.sh is sourced without editing PROJECT_ROOT/SCRATCH_ROOT.
/.local/

