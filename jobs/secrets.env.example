# MuCoDi-radiology secrets template.
#
# Copy to `jobs/secrets.env` (gitignored) and fill in. jobs/env.sh `set -a`-sources
# this file if present, so plain KEY=value lines are auto-exported (no `export`
# keyword needed). NEVER commit the filled-in jobs/secrets.env.
#
# Alternative for HF_TOKEN: `hf auth login` (or `huggingface-cli login`) writes the
# token to $HF_HOME/token, which jobs/env.sh surfaces as HF_TOKEN anyway.

# HuggingFace token for the gated repos ibrahimhamamci/CT-RATE (dataset + CT-CLIP weights),
# raidium/curia*, Pillar0, microsoft/BiomedVLP-CXR-BERT-specialized.
# Create at https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=

# Zenodo share-link JWT for the restricted RAD-ChestCT record (6406114).
# Obtained via the Zenodo "request access" flow; consumed by
# dataprep/datasets/radchestct.py (python -m dataprep.datasets radchestct --all).
ZENODO_RADCHESTCT_TOKEN=

# Kaggle API token (raw kaggle.json contents) for the gated Kaggle datasets MosMed, RSPECT, OSIC.
# Alternative: ~/.kaggle/access_token via the `kaggle` CLI.
KAGGLE_API_TOKEN=

# Redivis API token for Stanford AIMI COCA (coca, coca_gated).
REDIVIS_API_TOKEN=

# Optional: Weights & Biases API key (only if logging online; offline W&B needs none).
# WANDB_API_KEY=
